{
  parserClass="de.magynhard.crystal.parser.CrystalParser"

  extends="com.intellij.extapi.psi.ASTWrapperPsiElement"

  psiClassPrefix="Crystal"
  psiImplClassSuffix="Impl"
  psiPackage="de.magynhard.crystal.psi"
  psiImplPackage="de.magynhard.crystal.psi.impl"

  elementTypeHolderClass="de.magynhard.crystal.psi.CrystalTypes"
  elementTypeClass="de.magynhard.crystal.psi.CrystalElementType"
  tokenTypeClass="de.magynhard.crystal.lexer.CrystalTokenType"
  elementTypeFactory("class_definition|module_definition|struct_definition|enum_definition|method_definition|macro_definition")="de.magynhard.crystal.stubs.CrystalStubElementTypeFactory.create"

  tokens = [
    // Keywords
    ABSTRACT="ABSTRACT"
    ALIAS="ALIAS"
    ANNOTATION="ANNOTATION"
    AS="AS"
    AS_QUESTION="AS_QUESTION"
    ASM="ASM"
    BEGIN="BEGIN"
    BREAK="BREAK"
    CASE="CASE"
    CLASS="CLASS"
    DEF="DEF"
    DO="DO"
    ELSE="ELSE"
    ELSIF="ELSIF"
    END="END"
    ENSURE="ENSURE"
    ENUM="ENUM"
    EXTEND="EXTEND"
    FALSE="FALSE"
    FOR="FOR"
    FORALL="FORALL"
    FUN="FUN"
    IF="IF"
    IN="IN"
    INCLUDE="INCLUDE"
    INSTANCE_SIZEOF="INSTANCE_SIZEOF"
    IS_A="IS_A"
    LIB="LIB"
    MACRO="MACRO"
    MODULE="MODULE"
    NEXT="NEXT"
    NIL="NIL"
    NIL_QUESTION="NIL_QUESTION"
    OF="OF"
    OFFSETOF="OFFSETOF"
    OUT="OUT"
    POINTEROF="POINTEROF"
    PREVIOUS_DEF="PREVIOUS_DEF"
    PRIVATE="PRIVATE"
    PROTECTED="PROTECTED"
    REQUIRE="REQUIRE"
    RESCUE="RESCUE"
    RESPONDS_TO="RESPONDS_TO"
    RETURN="RETURN"
    SELECT="SELECT"
    SELF="SELF"
    SIZEOF="SIZEOF"
    STRUCT="STRUCT"
    SUPER="SUPER"
    THEN="THEN"
    TRUE="TRUE"
    TYPEOF="TYPEOF"
    UNINITIALIZED="UNINITIALIZED"
    UNION="UNION"
    UNLESS="UNLESS"
    UNTIL="UNTIL"
    VERBATIM="VERBATIM"
    WHEN="WHEN"
    WHILE="WHILE"
    WITH="WITH"
    YIELD="YIELD"

    // Literals
    INTEGER_LITERAL="INTEGER_LITERAL"
    FLOAT_LITERAL="FLOAT_LITERAL"
    CHAR_LITERAL="CHAR_LITERAL"
    STRING_LITERAL="STRING_LITERAL"
    STRING_INTERPOLATION_BEGIN="STRING_INTERPOLATION_BEGIN"
    STRING_INTERPOLATION_END="STRING_INTERPOLATION_END"
    COMMAND_LITERAL="COMMAND_LITERAL"
    REGEX_LITERAL="REGEX_LITERAL"
    SYMBOL_LITERAL="SYMBOL_LITERAL"
    HEREDOC_START="HEREDOC_START"
    HEREDOC_CONTENT="HEREDOC_CONTENT"
    HEREDOC_END="HEREDOC_END"
    STRING_ESCAPE="STRING_ESCAPE"
    PERCENT_LITERAL_BEGIN="PERCENT_LITERAL_BEGIN"
    PERCENT_LITERAL_END="PERCENT_LITERAL_END"
    PERCENT_SYMBOL_BEGIN="PERCENT_SYMBOL_BEGIN"
    PERCENT_SYMBOL_END="PERCENT_SYMBOL_END"
    SYMBOL_COLON="SYMBOL_COLON"

    // Macro body tokens
    MACRO_BODY_CONTENT="MACRO_BODY_CONTENT"
    MACRO_FRESH_VAR="MACRO_FRESH_VAR"
    MACRO_INTERPOLATION_BEGIN="MACRO_INTERPOLATION_BEGIN"
    MACRO_INTERPOLATION_END="MACRO_INTERPOLATION_END"
    MACRO_CONTROL_BEGIN="MACRO_CONTROL_BEGIN"
    MACRO_CONTROL_END="MACRO_CONTROL_END"

    // Identifiers
    IDENTIFIER="IDENTIFIER"
    CONSTANT="CONSTANT"
    INSTANCE_VAR="INSTANCE_VAR"
    CLASS_VAR="CLASS_VAR"
    GLOBAL_VAR="GLOBAL_VAR"

    // Operators
    PLUS="PLUS"
    MINUS="MINUS"
    STAR="STAR"
    SLASH="SLASH"
    DOUBLE_SLASH="DOUBLE_SLASH"
    PERCENT="PERCENT"
    AMPERSAND="AMPERSAND"
    PIPE="PIPE"
    CARET="CARET"
    TILDE="TILDE"
    DOUBLE_STAR="DOUBLE_STAR"
    WRAP_PLUS="WRAP_PLUS"
    WRAP_MINUS="WRAP_MINUS"
    WRAP_STAR="WRAP_STAR"
    WRAP_DOUBLE_STAR="WRAP_DOUBLE_STAR"
    LSHIFT="LSHIFT"
    RSHIFT="RSHIFT"
    EQ="EQ"
    NEQ="NEQ"
    LT="LT"
    GT="GT"
    LTE="LTE"
    GTE="GTE"
    SPACESHIP="SPACESHIP"
    CASE_EQ="CASE_EQ"
    MATCH_OP="MATCH_OP"
    BANG="BANG"
    AND_AND="AND_AND"
    OR_OR="OR_OR"
    ASSIGN="ASSIGN"
    PLUS_ASSIGN="PLUS_ASSIGN"
    MINUS_ASSIGN="MINUS_ASSIGN"
    STAR_ASSIGN="STAR_ASSIGN"
    SLASH_ASSIGN="SLASH_ASSIGN"
    PERCENT_ASSIGN="PERCENT_ASSIGN"
    AMPERSAND_ASSIGN="AMPERSAND_ASSIGN"
    PIPE_ASSIGN="PIPE_ASSIGN"
    CARET_ASSIGN="CARET_ASSIGN"
    DOUBLE_STAR_ASSIGN="DOUBLE_STAR_ASSIGN"
    WRAP_PLUS_ASSIGN="WRAP_PLUS_ASSIGN"
    WRAP_MINUS_ASSIGN="WRAP_MINUS_ASSIGN"
    WRAP_STAR_ASSIGN="WRAP_STAR_ASSIGN"
    WRAP_DOUBLE_STAR_ASSIGN="WRAP_DOUBLE_STAR_ASSIGN"
    DOUBLE_SLASH_ASSIGN="DOUBLE_SLASH_ASSIGN"
    LSHIFT_ASSIGN="LSHIFT_ASSIGN"
    RSHIFT_ASSIGN="RSHIFT_ASSIGN"
    OR_OR_ASSIGN="OR_OR_ASSIGN"
    AND_AND_ASSIGN="AND_AND_ASSIGN"
    DOT="DOT"
    DOTDOT="DOTDOT"
    DOTDOTDOT="DOTDOTDOT"
    ARROW="ARROW"
    DOUBLE_ARROW="DOUBLE_ARROW"
    QUESTION="QUESTION"
    COLON="COLON"
    DOUBLE_COLON="DOUBLE_COLON"
    SEMICOLON="SEMICOLON"
    COMMA="COMMA"
    HASH="HASH"
    AT="AT"

    // Delimiters
    LPAREN="LPAREN"
    RPAREN="RPAREN"
    LBRACKET="LBRACKET"
    RBRACKET="RBRACKET"
    LBRACE="LBRACE"
    RBRACE="RBRACE"

    // Whitespace & Comments
    LINE_COMMENT="LINE_COMMENT"
    NEWLINE="NEWLINE"
  ]
}

// ==================== Top Level ====================

crystalFile ::= top_level_statement*

private top_level_statement ::= NEWLINE
                              | SEMICOLON
                              | require_statement
                              | include_statement
                              | extend_statement
                              | annotation_usage
                              | class_definition
                              | module_definition
                              | struct_definition
                              | enum_definition
                              | lib_definition
                              | top_level_fun
                              | annotation_definition
                              | method_definition
                              | macro_definition
                              | alias_definition
                              | visibility_modifier
                              | macro_control
                              | statement

// ==================== Require / Include / Extend ====================

require_statement ::= REQUIRE string_expression {pin=1}

include_statement ::= INCLUDE type_reference {pin=1}

extend_statement ::= EXTEND (type_reference | SELF) {pin=1}

// ==================== Type Definitions ====================

class_definition ::= [ABSTRACT] CLASS type_name [type_parameters] [superclass_clause] class_body END {
  pin(".*")=2
  stubClass="de.magynhard.crystal.stubs.CrystalClassDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedClassDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

superclass_clause ::= LT type_reference

module_definition ::= MODULE type_name [type_parameters] class_body END {
  pin=1
  stubClass="de.magynhard.crystal.stubs.CrystalModuleDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedModuleDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

struct_definition ::= [ABSTRACT] STRUCT type_name [type_parameters] [superclass_clause] class_body END {
  pin(".*")=2
  stubClass="de.magynhard.crystal.stubs.CrystalStructDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedStructDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

enum_definition ::= ENUM type_name [COLON type_reference] enum_body END {
  pin=1
  stubClass="de.magynhard.crystal.stubs.CrystalEnumDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedEnumDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

lib_definition ::= LIB CONSTANT lib_body END {pin=1}

annotation_definition ::= ANNOTATION type_name NEWLINE* END {pin=1}

annotation_usage ::= AT LBRACKET type_path [LPAREN NLS argument_list NLS RPAREN] RBRACKET

alias_definition ::= ALIAS type_name ASSIGN type_reference {pin=1}

// ==================== Type Bodies ====================

class_body ::= class_member*

private class_member ::= NEWLINE
                        | SEMICOLON
                        | annotation_usage
                        | annotation_definition
                        | method_definition
                        | macro_definition
                        | class_definition
                        | module_definition
                        | struct_definition
                        | enum_definition
                        | include_statement
                        | extend_statement
                        | alias_definition
                        | visibility_modifier
                        | property_declaration
                        | macro_control
                        | statement

enum_body ::= enum_member*

private enum_member ::= NEWLINE | SEMICOLON | annotation_usage | enum_constant | method_definition

enum_constant ::= CONSTANT [ASSIGN expression]

lib_body ::= lib_member*

private lib_member ::= NEWLINE | SEMICOLON | fun_definition | type_alias_lib | lib_type_alias | lib_struct_definition | lib_union_definition | enum_definition | lib_external_var | lib_field

lib_field ::= IDENTIFIER COLON type_reference

lib_external_var ::= GLOBAL_VAR [ASSIGN string_expression] COLON type_reference

fun_definition ::= FUN IDENTIFIER [LPAREN NLS parameter_list NLS RPAREN] [COLON type_reference] {pin=1}

top_level_fun ::= FUN IDENTIFIER [LPAREN NLS parameter_list NLS RPAREN] [COLON type_reference] method_body END {pin=1}

type_alias_lib ::= ALIAS CONSTANT ASSIGN type_reference

lib_type_alias ::= IDENTIFIER CONSTANT ASSIGN type_reference

lib_struct_definition ::= STRUCT CONSTANT lib_body END

lib_union_definition ::= UNION CONSTANT lib_body END

// ==================== Methods ====================

method_definition ::= ABSTRACT DEF method_name [LPAREN NLS parameter_list NLS RPAREN] [COLON type_reference] [FORALL CONSTANT (COMMA CONSTANT)*]
                    | DEF method_name [LPAREN NLS parameter_list NLS RPAREN] [COLON type_reference] [FORALL CONSTANT (COMMA CONSTANT)*] method_body END {
  pin(".*")=2
  stubClass="de.magynhard.crystal.stubs.CrystalMethodDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedMethodDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

method_name ::= IDENTIFIER
              | SELF DOT (IDENTIFIER | CONSTANT | keyword_as_method | operator_method_name | macro_interpolation)
              | keyword_as_method
              | operator_method_name
              | macro_interpolation

private operator_method_name ::= PLUS | MINUS | STAR | SLASH | PERCENT | AMPERSAND | PIPE | CARET | TILDE
                               | WRAP_PLUS | WRAP_MINUS | WRAP_STAR | WRAP_DOUBLE_STAR
                                | DOUBLE_STAR | LSHIFT | RSHIFT | EQ | NEQ | LT | GT | LTE | GTE
                                | SPACESHIP | CASE_EQ | MATCH_OP | LBRACKET RBRACKET ASSIGN | LBRACKET RBRACKET QUESTION | LBRACKET RBRACKET

method_body ::= statement_list rescue_clause* [else_clause] [ensure_clause]

macro_body ::= macro_body_element*
private macro_body_element ::= MACRO_BODY_CONTENT
                             | MACRO_FRESH_VAR
                             | macro_interpolation
                             | macro_control
                             | NEWLINE
macro_interpolation ::= MACRO_INTERPOLATION_BEGIN expression MACRO_INTERPOLATION_END
macro_control ::= MACRO_CONTROL_BEGIN macro_control_token* MACRO_CONTROL_END
private macro_control_token ::= IDENTIFIER | CONSTANT | INSTANCE_VAR | CLASS_VAR
    | INTEGER_LITERAL | STRING_LITERAL | STRING_ESCAPE | STRING_INTERPOLATION_BEGIN | STRING_INTERPOLATION_END
    | SYMBOL_LITERAL | SYMBOL_COLON
    | TRUE | FALSE | NIL
    | IF | ELSE | ELSIF | END | FOR | IN | UNLESS | BEGIN | YIELD | VERBATIM
    | LPAREN | RPAREN | LBRACKET | RBRACKET | LBRACE | RBRACE | COMMA | DOT | COLON
    | EQ | NEQ | LT | GT | LTE | GTE | OR_OR | AND_AND | PIPE | AMPERSAND
    | ASSIGN | PLUS | MINUS | STAR | SLASH | QUESTION | BANG | DOTDOT | DOTDOTDOT
    | DOUBLE_COLON | PERCENT
    | NEWLINE | SEMICOLON | HASH | AT | ARROW | ANNOTATION

macro_definition ::= MACRO method_name [LPAREN NLS parameter_list NLS RPAREN] macro_body END {
  pin=1
  stubClass="de.magynhard.crystal.stubs.CrystalMacroDefinitionStub"
  mixin="de.magynhard.crystal.psi.impl.CrystalStubbedMacroDefinitionImpl"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

// ==================== Parameters ====================

parameter_list ::= [parameter_item (COMMA NLS parameter_item)* [COMMA]]
private parameter_item ::= bare_splat_separator | DOTDOTDOT | parameter

private param_prefix ::= annotation_usage
                       | macro_control
parameter ::= param_prefix* [STAR | DOUBLE_STAR | AMPERSAND] IDENTIFIER IDENTIFIER [COLON type_reference] [ASSIGN expression]
            | param_prefix* [STAR | DOUBLE_STAR | AMPERSAND] IDENTIFIER [COLON type_reference] [ASSIGN expression]
            | param_prefix* [STAR | DOUBLE_STAR | AMPERSAND] instance_var_access [COLON type_reference] [ASSIGN expression]
            | param_prefix* AMPERSAND COLON type_union (COMMA type_union)* ARROW [type_union]
            | param_prefix* AMPERSAND [COLON type_reference]
            | param_prefix* LPAREN IDENTIFIER (COMMA IDENTIFIER)* RPAREN {
  mixin="de.magynhard.crystal.psi.impl.CrystalParameterMixin"
}
private bare_splat_separator ::= STAR &(COMMA | RPAREN | NEWLINE)

// ==================== Property Declarations ====================

property_declaration ::= (instance_var_access | class_var_access | IDENTIFIER | SELF DOT IDENTIFIER) COLON type_reference [ASSIGN expression]

// ==================== Visibility ====================

visibility_modifier ::= (PRIVATE | PROTECTED) (method_definition | macro_definition | class_definition | struct_definition | constant_assignment | statement)
                      | (PRIVATE | PROTECTED) SELF DOT IDENTIFIER [call_args | bare_argument_list] [block]
                      | (PRIVATE | PROTECTED) &NEWLINE

// ==================== Statements ====================

statement_list ::= statement_or_separator*

private statement_or_separator ::= NEWLINE | SEMICOLON | statement

statement ::= if_statement
            | unless_statement
            | while_statement
            | until_statement
            | begin_statement
            | for_statement
            | select_statement
            | return_statement
            | break_statement
            | next_statement
            | yield_statement
            | with_yield_statement
            | include_statement
            | extend_statement
            | multi_assignment
            | property_declaration
            | assignment
            | constant_assignment
            | macro_control
            | expression_statement

expression_statement ::= expression [expression_assign_suffix [postfix_modifier] | postfix_modifier]

private expression_assign_suffix ::= assign_op NLS expression

postfix_modifier ::= (IF | UNLESS | WHILE | UNTIL | RESCUE) expression

// ==================== Control Flow ====================

if_statement ::= IF condition then_clause statement_list elsif_clause* [else_clause] END {pin=1}

unless_statement ::= UNLESS condition then_clause statement_list [else_clause] END {pin=1}

while_statement ::= WHILE condition then_clause statement_list END {pin=1}

until_statement ::= UNTIL condition then_clause statement_list END {pin=1}

condition ::= condition_assignment | expression
private condition_assignment ::= variable ASSIGN NLS expression

for_statement ::= FOR IDENTIFIER IN expression then_clause statement_list END {pin=1}

case_statement ::= CASE [expression] NEWLINE* (when_clause | in_clause)+ [else_clause] END {pin=1}

begin_statement ::= BEGIN statement_list rescue_clause* [else_clause] [ensure_clause] END {pin=1}

select_statement ::= SELECT NEWLINE+ select_when_clause+ [else_clause] END

select_when_clause ::= WHEN statement then_clause statement_list

private then_clause ::= THEN | NEWLINE | SEMICOLON

elsif_clause ::= ELSIF condition then_clause statement_list

else_clause ::= ELSE statement_list

when_clause ::= WHEN expression_list then_clause statement_list

in_clause ::= IN expression_list [IF expression] then_clause statement_list

rescue_clause ::= RESCUE [IDENTIFIER [COLON type_reference]] then_clause statement_list

ensure_clause ::= ENSURE statement_list

return_statement ::= RETURN postfix_modifier
                   | RETURN expression [postfix_modifier]
                   | RETURN {pin=1}

break_statement ::= BREAK postfix_modifier
                  | BREAK expression [postfix_modifier]
                  | BREAK {pin=1}

next_statement ::= NEXT postfix_modifier
                 | NEXT expression [postfix_modifier]
                 | NEXT {pin=1}

yield_statement ::= YIELD [LPAREN argument_list RPAREN | bare_argument_list] [postfix_modifier] {pin=1}
yield_expression ::= YIELD expression {pin=1}

with_yield_statement ::= WITH expression YIELD {pin=1}

// ==================== Assignments ====================

assignment ::= variable assign_op NLS (assignment | expression) [postfix_modifier] {pin=2
  mixin="de.magynhard.crystal.psi.impl.CrystalAssignmentMixin"
}

multi_assignment ::= multi_assign_target COMMA NLS multi_assign_target_list ASSIGN NLS multi_assign_values {pin=4}
private multi_assign_target_list ::= multi_assign_target (COMMA NLS multi_assign_target)*
multi_assign_target ::= STAR variable
                       | STAR UNDERSCORE
                       | variable [COLON type_reference]
                       | UNDERSCORE
                       | LPAREN multi_assign_target COMMA multi_assign_target_list RPAREN
private multi_assign_values ::= expression (COMMA expression)*

constant_assignment ::= CONSTANT ASSIGN NLS expression [postfix_modifier] {pin=2}

private variable ::= instance_var_access | class_var_access | GLOBAL_VAR | IDENTIFIER

private assign_op ::= ASSIGN | PLUS_ASSIGN | MINUS_ASSIGN | STAR_ASSIGN | SLASH_ASSIGN
                     | PERCENT_ASSIGN | AMPERSAND_ASSIGN | PIPE_ASSIGN | CARET_ASSIGN
                     | DOUBLE_STAR_ASSIGN | DOUBLE_SLASH_ASSIGN | LSHIFT_ASSIGN | RSHIFT_ASSIGN
                     | OR_OR_ASSIGN | AND_AND_ASSIGN
                     | WRAP_PLUS_ASSIGN | WRAP_MINUS_ASSIGN | WRAP_STAR_ASSIGN | WRAP_DOUBLE_STAR_ASSIGN

// ==================== Expressions ====================

expression ::= or_expression [QUESTION expression COLON expression]

private or_expression ::= and_expression (OR_OR NLS and_expression)*

private and_expression ::= not_expression (AND_AND NLS not_expression)*

private not_expression ::= BANG not_expression | comparison_expression

private comparison_expression ::= range_expression ((EQ | NEQ | LT | GT | LTE | GTE | SPACESHIP | CASE_EQ | MATCH_OP) NLS range_expression)*

private range_expression ::= [or_bitwise_expression] (DOTDOT | DOTDOTDOT) NLS [or_bitwise_expression]
                           | or_bitwise_expression

private or_bitwise_expression ::= xor_expression (PIPE NLS xor_expression)*

private xor_expression ::= and_bitwise_expression (CARET NLS and_bitwise_expression)*

private and_bitwise_expression ::= shift_expression (AMPERSAND NLS shift_expression)*

private shift_expression ::= additive_expression ((LSHIFT | RSHIFT) NLS additive_expression)*

private additive_expression ::= multiplicative_expression ((PLUS | MINUS | WRAP_PLUS | WRAP_MINUS) NLS multiplicative_expression)*

private multiplicative_expression ::= power_expression ((STAR | SLASH | DOUBLE_SLASH | PERCENT | WRAP_STAR) NLS power_expression)*

private power_expression ::= unary_expression ((DOUBLE_STAR | WRAP_DOUBLE_STAR) NLS unary_expression)*

private unary_expression ::= (PLUS | MINUS | TILDE | AMPERSAND | STAR | CARET) unary_expression
                            | postfix_expression

private postfix_expression ::= primary_expression postfix_op*

private postfix_op ::= NLS DOT (AS | AS_QUESTION | IS_A) LPAREN type_reference RPAREN
                     | NLS DOT (IDENTIFIER | CONSTANT | keyword_as_method | macro_interpolation) [call_args | bare_argument_list] [block]
                     | DOUBLE_COLON CONSTANT
                     | LBRACKET argument_list RBRACKET [QUESTION]
                     | call_args [block]
                     | NLS DOT IDENTIFIER assign_op expression

// Keywords that Crystal allows as method names after DOT
private keyword_as_method ::= ABSTRACT | ALIAS | AS | AS_QUESTION | ASM
                            | BEGIN | BREAK
                            | CASE | CLASS
                            | DEF | DO
                            | ELSE | ELSIF | END | ENSURE | ENUM | EXTEND
                            | FALSE | FOR | FORALL | FUN
                            | IF | IN | INCLUDE | INSTANCE_SIZEOF | IS_A
                            | LIB
                            | MACRO | MODULE
                            | NEXT | NIL | NIL_QUESTION
                            | OF | OFFSETOF | OUT
                            | POINTEROF | PREVIOUS_DEF | PRIVATE | PROTECTED
                            | REQUIRE | RESCUE | RESPONDS_TO | RETURN
                            | SELECT | SELF | SIZEOF | STRUCT | SUPER
                            | THEN | TRUE | TYPEOF
                            | UNINITIALIZED | UNION | UNLESS | UNTIL
                            | VERBATIM
                            | WHEN | WHILE | WITH
                            | YIELD
                            | PLUS | MINUS | STAR | SLASH | PERCENT | DOUBLE_STAR
                            | EQ | NEQ | LT | GT | LTE | GTE | SPACESHIP
                            | LSHIFT | RSHIFT | AMPERSAND | PIPE | CARET | TILDE
                            | DOUBLE_SLASH

// ==================== Primary Expressions ====================

private primary_expression ::= grouped_expression
                             | array_literal
                             | hash_literal
                             | tuple_literal
                             | proc_literal
                             | DOUBLE_COLON CONSTANT
                             | method_call_expression
                             | implicit_object_call
                             | literal
                             | instance_var_access
                             | class_var_access
                             | variable_reference
                             | typeof_expression
                             | sizeof_expression
                             | instance_sizeof_expression
                              | pointerof_expression
                             | offsetof_expression
                                   | uninitialized_expression
                                   | asm_expression
                                   | macro_interpolation
                              | yield_expression
                              | macro_interpolation
                              | if_statement
                              | unless_statement
                             | case_statement
                             | begin_statement

grouped_expression ::= LPAREN NLS expression [assign_op NLS expression] NLS RPAREN

method_call_expression ::= (IDENTIFIER | CONSTANT | SELECT) call_args [block]
                         | (IDENTIFIER | CONSTANT | SELECT) !LBRACKET !binary_op_lookahead bare_argument_list [block]
                         | (IDENTIFIER | CONSTANT) block
                         | (SUPER | PREVIOUS_DEF) call_args
                         | (SUPER | PREVIOUS_DEF) bare_argument_list {
  mixin="de.magynhard.crystal.psi.impl.CrystalMethodCallExpressionMixin"
}

// Prevent bare_argument_list from consuming binary operators followed by IDENTIFIER
// as bare unary expressions. Without this, "width + height" is parsed as method call
// "width(+height)" instead of the binary expression "width + height".
// Also blocks *, /, % etc. so that "x * scalar" inside parenthesized calls is not
// misparsed as bare method call "x" with arguments "* scalar".
// Tradeoff: bare calls with splat like "add *args" need parentheses: "add(*args)".
private binary_op_lookahead ::= (PLUS | MINUS | STAR | SLASH | DOUBLE_SLASH | PERCENT | DOUBLE_STAR) IDENTIFIER

// Implicit object call: .method? or .operator (used in &.foo shorthand and case/when patterns)
implicit_object_call ::= DOT (IDENTIFIER | RESPONDS_TO | IS_A | NIL_QUESTION | operator_method_name) [call_args]

call_args ::= LPAREN NLS argument_list NLS RPAREN
            | LPAREN RPAREN

argument_list ::= argument (NLS COMMA NLS argument)* [NLS COMMA]

argument ::= STAR expression
           | DOUBLE_STAR expression
           | AMPERSAND expression
           | OUT IDENTIFIER
           | named_argument
           | expression

// Named argument: requires both IDENTIFIER and COLON to match before committing.
// Without pin=2, the optional [IDENTIFIER COLON] prefix would greedily consume
// IDENTIFIER even when COLON doesn't follow, causing binary expressions like
// x * 2 to be misparsed (x consumed, * 2 treated as unary star expression).
private named_argument ::= IDENTIFIER COLON expression {pin=2}

// Bare (parenthesis-free) arguments — used for calls like: describe App5 do ... end
bare_argument_list ::= bare_argument (COMMA bare_argument)*

bare_argument ::= named_bare_argument
                | STAR bare_expression
                | DOUBLE_STAR bare_expression
                | bare_expression
                | OUT IDENTIFIER

// Named bare argument: requires both IDENTIFIER and COLON to match before committing.
// Without pin=2, the optional [IDENTIFIER COLON] prefix would greedily consume
// IDENTIFIER even when COLON doesn't follow, causing binary expressions like
// x * scalar to be misparsed (x consumed, * scalar treated as unary star).
private named_bare_argument ::= IDENTIFIER COLON bare_expression [ASSIGN bare_expression] {pin=2}

// Bare expression: same as expression but does not consume blocks or assignments
// This prevents the bare argument from eating the 'do' that belongs to the outer method call
private bare_expression ::= bare_or_expression [QUESTION expression COLON expression]

private bare_or_expression ::= bare_and_expression (OR_OR NLS bare_and_expression)*

private bare_and_expression ::= bare_not_expression (AND_AND NLS bare_not_expression)*

private bare_not_expression ::= BANG bare_not_expression | bare_comparison_expression

private bare_comparison_expression ::= bare_range_expression ((EQ | NEQ | LT | GT | LTE | GTE | SPACESHIP | CASE_EQ | MATCH_OP) NLS bare_range_expression)*

private bare_range_expression ::= [bare_or_bitwise_expression] (DOTDOT | DOTDOTDOT) NLS [bare_or_bitwise_expression]
                               | bare_or_bitwise_expression

private bare_or_bitwise_expression ::= bare_xor_expression (PIPE NLS bare_xor_expression)*

private bare_xor_expression ::= bare_and_bitwise_expression (CARET NLS bare_and_bitwise_expression)*

private bare_and_bitwise_expression ::= bare_shift_expression (AMPERSAND NLS bare_shift_expression)*

private bare_shift_expression ::= bare_additive_expression ((LSHIFT | RSHIFT) NLS bare_additive_expression)*

private bare_additive_expression ::= bare_multiplicative_expression ((PLUS | MINUS | WRAP_PLUS | WRAP_MINUS) NLS bare_multiplicative_expression)*

private bare_multiplicative_expression ::= bare_power_expression ((STAR | SLASH | DOUBLE_SLASH | PERCENT | WRAP_STAR) NLS bare_power_expression)*

private bare_power_expression ::= bare_unary_expression ((DOUBLE_STAR | WRAP_DOUBLE_STAR) NLS bare_unary_expression)*

private bare_unary_expression ::= (PLUS | MINUS | TILDE | AMPERSAND | STAR) bare_unary_expression
                                | bare_postfix_expression

private bare_postfix_expression ::= bare_primary_expression bare_postfix_op*

private bare_postfix_op ::= NLS DOT (AS | AS_QUESTION | IS_A) LPAREN type_reference RPAREN
                           | NLS DOT (IDENTIFIER | CONSTANT | keyword_as_method | macro_interpolation) [call_args | bare_argument_list]
                          | DOUBLE_COLON CONSTANT
                          | LBRACKET argument_list RBRACKET [QUESTION]
                          | call_args

// Bare primary: like primary but no blocks or method calls with bare args (to prevent ambiguity)
private bare_primary_expression ::= grouped_expression
                                  | array_literal
                                  | hash_literal
                                  | tuple_literal
                                  | proc_literal
                                  | bare_method_call_expression
                                  | literal
                                  | instance_var_access
                                  | class_var_access
                                  | variable_reference
                                  | typeof_expression
                                  | sizeof_expression
                                  | instance_sizeof_expression
                                  | pointerof_expression
                                  | offsetof_expression
                                   | uninitialized_expression
                                   | asm_expression
                                   | macro_interpolation

bare_method_call_expression ::= (IDENTIFIER | CONSTANT) call_args {
  mixin="de.magynhard.crystal.psi.impl.CrystalBareMethodCallExpressionMixin"
}

block ::= DO [PIPE NLS parameter_list NLS PIPE] statement_list rescue_clause* [else_clause] [ensure_clause] END
        | LBRACE [PIPE NLS parameter_list NLS PIPE] statement_list RBRACE

// Proc/Lambda literal: ->{ body }, ->(params) { body }, ->method_name(types)
proc_literal ::= ARROW LPAREN NLS parameter_list NLS RPAREN LBRACE statement_list RBRACE
               | ARROW LBRACE statement_list RBRACE
               | ARROW (IDENTIFIER | CONSTANT) [DOT (IDENTIFIER | CONSTANT)] [LPAREN type_reference (COMMA type_reference)* RPAREN] {pin=1}

// ==================== Literals ====================

private literal ::= INTEGER_LITERAL
                  | FLOAT_LITERAL
                  | CHAR_LITERAL
                  | string_expression
                  | symbol_string_expression
                  | SYMBOL_LITERAL
                  | regex_expression
                  | COMMAND_LITERAL
                  | NIL
                  | TRUE
                  | FALSE
                  | SELF
                  | SUPER
                  | PREVIOUS_DEF
                  | heredoc_literal
                  | percent_literal

string_expression ::= (STRING_LITERAL | STRING_ESCAPE | STRING_INTERPOLATION_BEGIN expression STRING_INTERPOLATION_END)+
regex_expression ::= REGEX_LITERAL

heredoc_literal ::= HEREDOC_START (HEREDOC_CONTENT | STRING_ESCAPE | STRING_INTERPOLATION_BEGIN expression STRING_INTERPOLATION_END)* HEREDOC_END?

percent_literal ::= PERCENT_LITERAL_BEGIN percent_literal_content* PERCENT_LITERAL_END
                  | PERCENT_SYMBOL_BEGIN percent_symbol_content* PERCENT_SYMBOL_END
private percent_literal_content ::= STRING_LITERAL | STRING_ESCAPE | SYMBOL_LITERAL | REGEX_LITERAL | COMMAND_LITERAL | NEWLINE
private percent_symbol_content ::= SYMBOL_LITERAL | NEWLINE

symbol_string_expression ::= SYMBOL_COLON (STRING_LITERAL | STRING_ESCAPE | STRING_INTERPOLATION_BEGIN expression STRING_INTERPOLATION_END)+

array_literal ::= LBRACKET NLS [expression_list] NLS RBRACKET [OF type_reference]

hash_literal ::= LBRACE NLS [hash_entry_list] NLS RBRACE [OF type_reference DOUBLE_ARROW type_reference]

tuple_literal ::= LBRACE NLS expression_list NLS RBRACE

hash_entry_list ::= hash_entry (NLS COMMA NLS hash_entry)* [COMMA]

hash_entry ::= expression (DOUBLE_ARROW | COLON) expression

// ==================== Variable References ====================

instance_var_access ::= INSTANCE_VAR {
  mixin="de.magynhard.crystal.psi.impl.CrystalInstanceVarAccessMixin"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

class_var_access ::= CLASS_VAR {
  mixin="de.magynhard.crystal.psi.impl.CrystalClassVarAccessMixin"
  implements="de.magynhard.crystal.psi.CrystalNamedElement"
}

variable_reference ::= GLOBAL_VAR | IDENTIFIER | CONSTANT {
  mixin="de.magynhard.crystal.psi.impl.CrystalVariableReferenceMixin"
}

// ==================== Type References ====================

type_reference ::= type_union [ARROW [type_union]]
                 | ARROW [type_union]

private type_union ::= type_single (PIPE NLS type_single)*

private type_single ::= STAR type_path [type_arguments] [QUESTION]
                       | type_path [type_arguments] [DOT CLASS] [QUESTION] (STAR | DOUBLE_STAR)* [LBRACKET INTEGER_LITERAL RBRACKET]
                       | SELF [QUESTION]
                       | TYPEOF LPAREN NLS expression (COMMA NLS expression)* NLS RPAREN [QUESTION]
                       | LPAREN type_reference (COMMA type_reference)* RPAREN
                       | LBRACE NLS IDENTIFIER COLON type_reference (NLS COMMA NLS IDENTIFIER COLON type_reference)* NLS RBRACE
                       | LBRACE NLS type_reference (NLS COMMA NLS type_reference)* NLS RBRACE
                       | IDENTIFIER

type_path ::= [DOUBLE_COLON] CONSTANT (DOUBLE_COLON CONSTANT)* {
  mixin="de.magynhard.crystal.psi.impl.CrystalTypePathMixin"
}

type_arguments ::= LPAREN NLS type_argument (NLS COMMA NLS type_argument)* [NLS COMMA] NLS RPAREN

private type_argument ::= type_reference | INTEGER_LITERAL

type_parameters ::= LPAREN NLS type_parameter_item (COMMA NLS type_parameter_item)* [COMMA] NLS RPAREN
private type_parameter_item ::= [STAR] CONSTANT [ASSIGN type_reference]

// ==================== Type Names ====================

type_name ::= CONSTANT (DOUBLE_COLON CONSTANT)*

// ==================== Typeof / Sizeof ====================

typeof_expression ::= TYPEOF LPAREN expression RPAREN {pin=1}

sizeof_expression ::= SIZEOF LPAREN NLS type_reference NLS RPAREN {pin=1}

instance_sizeof_expression ::= INSTANCE_SIZEOF LPAREN NLS type_reference NLS RPAREN {pin=1}

pointerof_expression ::= POINTEROF LPAREN NLS (instance_var_access | class_var_access | variable_reference) NLS RPAREN {pin=1}

offsetof_expression ::= OFFSETOF LPAREN NLS type_reference COMMA NLS instance_var_access NLS RPAREN {pin=1}

uninitialized_expression ::= UNINITIALIZED type_reference {pin=1}

asm_expression ::= ASM LPAREN NLS string_expression NLS [asm_sections] NLS RPAREN {pin=1}

// ASM sections: up to 4 colon-separated sections (outputs, inputs, clobbers, options)
// DOUBLE_COLON (::) counts as two consecutive colons (skipping a section)
private asm_sections ::= DOUBLE_COLON NLS COLON NLS [asm_clobber_list] [NLS COLON NLS [asm_option_list]]
                       | DOUBLE_COLON NLS [asm_operand_list] [NLS COLON NLS [asm_clobber_list] [NLS COLON NLS [asm_option_list]]]
                       | COLON NLS [asm_operand_list] NLS DOUBLE_COLON NLS [asm_clobber_list] [NLS COLON NLS [asm_option_list]]
                       | COLON NLS [asm_operand_list] [NLS COLON NLS [asm_operand_list] [NLS COLON NLS [asm_clobber_list] [NLS COLON NLS [asm_option_list]]]]

private asm_operand_list ::= asm_operand (NLS COMMA NLS asm_operand)*

asm_operand ::= string_expression LPAREN expression RPAREN

private asm_clobber_list ::= string_expression (NLS COMMA NLS string_expression)*

private asm_option_list ::= string_expression (NLS COMMA NLS string_expression)*

// ==================== Expression Lists ====================

expression_list ::= expression (NLS COMMA NLS expression)* [COMMA]

// ==================== Helper Rules ====================

private NLS ::= NEWLINE*
